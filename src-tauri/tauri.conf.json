{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Repo Dashboard",
  "version": "0.2.9",
  "identifier": "no.nordlabs.repodashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Repo Dashboard",
        "width": 1280,
        "height": 820,
        "minWidth": 780,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/anders-vedal/git-orchestrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMTBFNzVCM0VERUM0QkEKUldTNnhONCtXK2NRSU5DbXMxQXFIWmJtWnBwTStsVFV4UlJiNWhOTnpZdHZ0WVdIZ1RLb01lZWYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
