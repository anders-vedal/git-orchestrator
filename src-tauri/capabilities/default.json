{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — dialog open, opener restricted to http/https URLs and local paths",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "os:allow-platform",
    "updater:default",
    "process:allow-restart",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    }
  ]
}
